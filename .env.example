# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# ── AI providers ─────────────────────────────────────────────────────────────
# At least one of the two keys below is required for AI agent endpoints.
# CRUD task management works without any AI key.
#
# Priority: Gemini is tried first (fastest/cheapest). When its quota is
# exhausted — or if the key is absent — Claude Haiku is used as fallback.

# Google Gemini (primary)
GEMINI_API_KEY=

# Anthropic Claude Haiku (fallback)
ANTHROPIC_API_KEY=

# ── Optional overrides ────────────────────────────────────────────────────────

# Ordered Gemini model fallback list (comma-separated, first = preferred)
# AI_MODELS=gemini-2.5-flash,gemini-2.0-flash,gemini-1.5-flash

# SQLite database path (relative to project root)
# DB_PATH=data/devlog.db
