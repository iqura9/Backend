# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# ── AI providers ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
AI_PROVIDER_PRIORITY=claude #"gemini or claude"


# ── Optional overrides ────────────────────────────────────────────────────────

# Ordered Gemini model fallback list (comma-separated, first = preferred)
# AI_MODELS=gemini-2.5-flash,gemini-3.5-flash,gemini-3.1-flash-lite,gemini-2.5-flash-lite,gemini-3-flash

# SQLite database path (relative to project root)
# DB_PATH=data/devlog.db
