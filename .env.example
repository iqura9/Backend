# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Gemini AI (required for AI agent endpoints; CRUD works without it)
GEMINI_API_KEY=

# Optional: override the ordered model fallback list (comma-separated)
# AI_MODELS=gemini-2.5-flash,gemini-2.0-flash,gemini-1.5-flash

# Optional: override the SQLite database path (relative to project root)
# DB_PATH=data/devlog.db
